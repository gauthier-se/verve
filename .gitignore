# --- Personal / sensitive data ---
sample_data/

# --- Verve runtime data ---
# The data directory (verve.db, artifacts/, imports).
/data/
*.db
*.db-wal
*.db-shm
artifacts/

# --- Go ---
/bin/
# Root-level built binary (anchored so it doesn't match the cmd/verve/ source dir).
/verve
*.test
*.out
coverage.*

# --- Node / front-end ---
node_modules/
.vite/
*.local

# Built SPA assets are embedded via go:embed at build time, not committed. Keep
# the dist directory itself (its .gitkeep placeholder lets `go:embed` compile
# before the UI is built) but ignore the Vite build output written into it.
/internal/web/dist/*
!/internal/web/dist/.gitkeep

# --- Editors / OS ---
.DS_Store
.idea/
.vscode/
*.swp
.env

# --- Nix / direnv ---
# .envrc is committed (it just does `use flake`); the local direnv cache is not.
.direnv/
